# MumbleSDK 应用配置样例（properties-only）
# 说明：
# - 该文件为可复制的样例，用于 Spring Boot + MumbleSDK 项目基础配置。
# - 使用时请复制为 application-dev.properties / application-test.properties / application-prod.properties 等环境文件。
# - 所有占位值请替换为你们的实际配置。
# - 重点：仅使用 .properties 格式进行配置（不使用 YAML），遵循“properties-only”约定。

############################
# 基础应用信息
############################
spring.application.name=mumblesdk-demo
server.port=8080
server.servlet.context-path=/

# MVC 异步超时（DeferredResult）
spring.mvc.async.request-timeout=30s

############################
# 日志与 MDC（包含 bizSeqNo/txnSeqNo）
############################
# 按需调整日志级别
logging.level.root=INFO
logging.level.com.yourorg=INFO

# 推荐在日志 Pattern 中包含链路字段（bizSeqNo/txnSeqNo），确保通过 MumbleContextUtil 注入到 MDC
# 以下为 Logback 常见 pattern 的示例，请在你们工程的 logback-spring.xml 中设置（此处仅做说明）：
# <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - biz=%X{bizSeqNo} txn=%X{txnSeqNo} - %msg%n</pattern>

############################
# 数据源（HikariCP）
############################
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
spring.datasource.url=jdbc:mysql://127.0.0.1:3306/mumble_demo?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false
spring.datasource.username=demo_user
spring.datasource.password=demo_pass

# Hikari 连接池配置
spring.datasource.hikari.pool-name=HikariPool-Mumble
spring.datasource.hikari.maximum-pool-size=20
spring.datasource.hikari.minimum-idle=5
spring.datasource.hikari.idle-timeout=600000
spring.datasource.hikari.connection-timeout=30000
spring.datasource.hikari.max-lifetime=1800000
spring.datasource.hikari.auto-commit=true

############################
# MyBatis 基本配置
############################
# Mapper XML 扫描路径（按需调整）
mybatis.mapper-locations=classpath*:mapper/**/*.xml
# 别名包（按需调整）
mybatis.type-aliases-package=com.yourorg.project.dao.model
# 核心配置项（示例）
mybatis.configuration.map-underscore-to-camel-case=true
mybatis.configuration.default-statement-timeout=30
mybatis.configuration.safe-row-bounds-enabled=true
mybatis.configuration.call-setters-on-nulls=true
# 禁止未设置参数的调用（建议在代码中确保所有参数均声明 jdbcType）
# 其他：避免 select *；在 XML 中定义 BaseResultMap / Base_Column_List

############################
# 线程池（Spring Task Execution）
############################
# Web 层异步执行器（示例）
spring.task.execution.pool.core-size=8
spring.task.execution.pool.max-size=32
spring.task.execution.pool.queue-capacity=1000
spring.task.execution.thread-name-prefix=front-exec-
spring.task.execution.shutdown.await-termination=true
spring.task.execution.shutdown.await-termination-period=10s

############################
# HTTP 客户端（示例）
############################
# 如果使用 Spring WebClient 或 RestTemplate，可配置连接池/超时（以下按实际客户端配置）
# 示例（WebClient 配置通常在代码中进行，这里仅做占位说明）
# webclient.connect-timeout=3000
# webclient.read-timeout=5000

############################
# MumbleSDK 相关配置（按需调整为真实键名）
############################
# 序列服务（示例）
mumble.seq.endpoint=http://127.0.0.1:9000/seq
mumble.seq.biz-key-prefix=BIZ_SEQ_
mumble.seq.txn-key-prefix=TXN_SEQ_

# 分布式锁（示例）
mumble.lock.provider=redis
mumble.lock.redis.host=127.0.0.1
mumble.lock.redis.port=6379
mumble.lock.redis.password=
mumble.lock.wait-ms=200
mumble.lock.lease-ms=5000

# RMB 消息（示例）
mumble.rmb.enabled=true
mumble.rmb.bootstrap=127.0.0.1:9092
mumble.rmb.topic.order.created=order.created
mumble.rmb.group.order.service=order-service
# 其他消费/生产相关参数按需补充

############################
# 事务与异常
############################
# 建议统一在 Service 层声明 @Transactional(rollbackFor = Exception.class)
# 控制器层不启用事务，统一使用抽象控制器 execute(...) 模板方法处理异步与异常转换

############################
# Actuator（可选）
############################
management.endpoints.web.exposure.include=health,info,metrics,loggers
management.endpoint.health.show-details=always

############################
# 环境切换
############################
# application-dev.properties / application-test.properties / application-prod.properties
# 建议在不同环境中：
# - 调整数据源、MQ、锁服务、序列服务等连接信息
# - 配置差异化的日志级别与输出
# - 覆盖 thread pool/timeout 等性能相关参数

############################
# 说明与提醒
############################
# - properties-only：所有配置文件使用 .properties 格式，避免 YAML
# - 日志链路：确保将 bizSeqNo/txnSeqNo 写入 MDC 并在日志 pattern 中打印
# - 校验与国际化：提供 messages.properties，统一校验提示 Key
# - DAO/Mapper/XML：遵循最佳实践，避免 select *，参数声明 jdbcType，明确 where 条件
# - 幂等与锁控：关键业务流程（RMB 消费、创建流程）确保幂等与锁控
