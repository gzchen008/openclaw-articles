#!/bin/bash
# OpenClaw 备份与恢复工具
# 用法: openclaw-backup [backup|restore|list] [备份文件名]

set -e

OPENCLAW_DIR="${HOME}/.openclaw"
BACKUP_DIR="${HOME}/openclaw-backups"
ACTION="${1:-help}"
FILENAME="${2:-}"

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# 禁用颜色如果输出不是终端
if [ ! -t 1 ]; then
    RED=''
    GREEN=''
    YELLOW=''
    BLUE=''
    NC=''
fi

# 显示帮助
show_help() {
    echo -e "${BLUE}OpenClaw 备份与恢复工具${NC}"
    echo ""
    echo "用法:"
    echo "  openclaw-backup backup [文件名]     创建备份"
    echo "  openclaw-backup restore [文件名]    恢复备份"
    echo "  openclaw-backup list                列出所有备份"
    echo "  openclaw-backup help                显示帮助"
    echo ""
    echo "示例:"
    echo "  openclaw-backup backup              创建带时间戳的备份"
    echo "  openclaw-backup backup my-backup    创建名为 my-backup 的备份"
    echo "  openclaw-backup restore             恢复最近的备份"
    echo "  openclaw-backup restore my-backup   恢复指定备份"
}

# 确保备份目录存在
ensure_backup_dir() {
    if [ ! -d "$BACKUP_DIR" ]; then
        mkdir -p "$BACKUP_DIR"
        echo -e "${GREEN}✓${NC} 创建备份目录: $BACKUP_DIR"
    fi
}

# 检查 OpenClaw 是否安装
check_openclaw() {
    if [ ! -d "$OPENCLAW_DIR" ]; then
        echo -e "${RED}✗${NC} 未找到 OpenClaw 目录: $OPENCLAW_DIR"
        echo "   OpenClaw 可能未安装"
        exit 1
    fi
}

# 创建备份
do_backup() {
    check_openclaw
    ensure_backup_dir
    
    # 生成文件名
    if [ -z "$FILENAME" ] || [ "$FILENAME" == "auto" ]; then
        TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
        FILENAME="openclaw-backup-${TIMESTAMP}"
    fi
    
    # 确保文件名有 .tar.gz 后缀
    if [[ ! "$FILENAME" == *.tar.gz ]]; then
        FILENAME="${FILENAME}.tar.gz"
    fi
    
    BACKUP_PATH="${BACKUP_DIR}/${FILENAME}"
    
    echo -e "${BLUE}📦 创建备份...${NC}"
    echo "   源目录: $OPENCLAW_DIR"
    echo "   备份文件: $BACKUP_PATH"
    
    # 创建临时清单文件
    TEMP_LIST=$(mktemp)
    
    # 添加需要备份的目录到清单（排除 backups 目录）
    # 使用 find 排除 backups 目录，避免递归备份
    find "$OPENCLAW_DIR" -maxdepth 1 -mindepth 1 ! -name "backups" -type d > "$TEMP_LIST"
    find "$OPENCLAW_DIR" -maxdepth 1 -type f >> "$TEMP_LIST"
    
    # 创建 tar 包
    tar -czf "$BACKUP_PATH" -T "$TEMP_LIST" 2>/dev/null || {
        echo -e "${RED}✗${NC} 备份失败"
        rm -f "$TEMP_LIST"
        exit 1
    }
    
    rm -f "$TEMP_LIST"
    
    # 显示备份信息
    BACKUP_SIZE=$(du -h "$BACKUP_PATH" | cut -f1)
    echo -e "${GREEN}✓${NC} 备份完成!"
    echo "   文件: $FILENAME"
    echo "   大小: $BACKUP_SIZE"
    echo "   位置: $BACKUP_PATH"
    
    # 清理旧备份（保留最近7天）
    cleanup_old_backups
}

# 清理旧备份（保留最近7天）
cleanup_old_backups() {
    echo ""
    echo -e "${BLUE}🧹 清理旧备份（保留最近7天）...${NC}"
    
    # 统计删除前的备份数量
    BEFORE_COUNT=$(find "$BACKUP_DIR" -name "openclaw-backup-*.tar.gz" -type f 2>/dev/null | wc -l)
    
    # 删除7天前的备份
    find "$BACKUP_DIR" -name "openclaw-backup-*.tar.gz" -type f -mtime +7 -delete 2>/dev/null || true
    
    # 统计删除后的备份数量
    AFTER_COUNT=$(find "$BACKUP_DIR" -name "openclaw-backup-*.tar.gz" -type f 2>/dev/null | wc -l)
    DELETED_COUNT=$((BEFORE_COUNT - AFTER_COUNT))
    
    if [ "$DELETED_COUNT" -gt 0 ]; then
        echo -e "${GREEN}✓${NC} 已清理 $DELETED_COUNT 个旧备份"
    else
        echo -e "${GREEN}✓${NC} 没有需要清理的旧备份"
    fi
    echo "   当前保留: $AFTER_COUNT 个备份"
}

# 列出备份
do_list() {
    ensure_backup_dir
    
    echo -e "${BLUE}📋 备份列表${NC}"
    echo ""
    
    if [ ! "$(ls -A $BACKUP_DIR/*.tar.gz 2>/dev/null)" ]; then
        echo "   没有找到备份文件"
        echo "   备份目录: $BACKUP_DIR"
        return
    fi
    
    printf "%-25s %-10s %-20s\n" "文件名" "大小" "创建时间"
    printf "%-25s %-10s %-20s\n" "-------------------------" "----------" "--------------------"
    
    for file in "$BACKUP_DIR"/*.tar.gz; do
        if [ -f "$file" ]; then
            filename=$(basename "$file")
            size=$(du -h "$file" | cut -f1)
            mtime=$(stat -c "%Y" "$file" 2>/dev/null || stat -f "%m" "$file" 2>/dev/null)
            date_str=$(date -r "$mtime" "+%Y-%m-%d %H:%M:%S" 2>/dev/null || date -d "@$mtime" "+%Y-%m-%d %H:%M:%S" 2>/dev/null)
            printf "%-25s %-10s %-20s\n" "$filename" "$size" "$date_str"
        fi
    done
}

# 恢复备份
do_restore() {
    ensure_backup_dir
    
    # 如果没有指定文件名，使用最新的备份
    if [ -z "$FILENAME" ]; then
        LATEST_BACKUP=$(ls -t "$BACKUP_DIR"/*.tar.gz 2>/dev/null | head -1)
        if [ -z "$LATEST_BACKUP" ]; then
            echo -e "${RED}✗${NC} 没有找到备份文件"
            echo "   备份目录: $BACKUP_DIR"
            exit 1
        fi
        FILENAME=$(basename "$LATEST_BACKUP")
        echo -e "${YELLOW}⚠${NC} 未指定备份文件，将使用最新备份: $FILENAME"
    fi
    
    # 确保文件名有 .tar.gz 后缀
    if [[ ! "$FILENAME" == *.tar.gz ]]; then
        FILENAME="${FILENAME}.tar.gz"
    fi
    
    BACKUP_PATH="${BACKUP_DIR}/${FILENAME}"
    
    if [ ! -f "$BACKUP_PATH" ]; then
        echo -e "${RED}✗${NC} 备份文件不存在: $BACKUP_PATH"
        exit 1
    fi
    
    echo -e "${YELLOW}⚠${NC} 警告: 恢复将覆盖当前的 OpenClaw 数据!"
    echo "   备份文件: $BACKUP_PATH"
    echo "   目标目录: $OPENCLAW_DIR"
    echo ""
    read -p "确定要继续吗? (yes/no): " confirm
    
    if [ "$confirm" != "yes" ]; then
        echo -e "${YELLOW}已取消${NC}"
        exit 0
    fi
    
    # 先创建当前数据的备份（以防万一）
    if [ -d "$OPENCLAW_DIR" ]; then
        SAFETY_BACKUP="${BACKUP_DIR}/auto-safety-$(date +%Y%m%d_%H%M%S).tar.gz"
        echo -e "${BLUE}💾 创建安全备份...${NC}"
        tar -czf "$SAFETY_BACKUP" "$OPENCLAW_DIR" 2>/dev/null || true
        echo "   安全备份: $(basename "$SAFETY_BACKUP")"
    fi
    
    # 恢复备份
    echo -e "${BLUE}📦 恢复备份...${NC}"
    
    # 删除现有目录
    if [ -d "$OPENCLAW_DIR" ]; then
        rm -rf "$OPENCLAW_DIR"
    fi
    
    # 解压备份
    tar -xzf "$BACKUP_PATH" -C "${HOME}"
    
    echo -e "${GREEN}✓${NC} 恢复完成!"
    echo ""
    echo "建议操作:"
    echo "  1. 检查配置: openclaw config get"
    echo "  2. 重启 Gateway: openclaw gateway restart"
    echo "  3. 检查状态: openclaw status"
}

# 主逻辑
case "$ACTION" in
    backup)
        do_backup
        ;;
    restore)
        do_restore
        ;;
    list)
        do_list
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        echo -e "${RED}✗${NC} 未知命令: $ACTION"
        show_help
        exit 1
        ;;
esac
