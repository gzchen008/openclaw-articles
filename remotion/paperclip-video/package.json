{
  "name": "paperclip-video",
  "version": "1.0.0",
  "scripts": {
    "build": "remotion bundle build src/index.ts --bundle=cjs",
    "render": "remotion render src/index.ts PaperclipVideo out/out/paperclip.mp4 --concurrency 1",
    "dev": "remotion watch src/index.ts --bundle=cjs",
    "upgrade": "remotion bundle upgrade src/index.ts --bundle=cjs"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.435",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remotion": "^4.0.435"
  }
}
